{
  "name": "voxel-engine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run lint && npm run format && npm run typecheck",
    "dev": "vite",
    "build": "npm run predev && tsc -b && vite build",
    "github-pages": "npm run predev && tsc -b && vite build --outDir ./docs",
    "lint": "eslint ./src --fix",
    "format": "prettier --write ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@react-three/fiber": "9.6.0",
    "leva": "0.10.1",
    "lucide-react": "1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "simplex-noise": "4.0.3",
    "three": "0.184.0",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.0",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.5.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-import-resolver-typescript": "3.6.3",
    "eslint-plugin-import": "2.30.0",
    "eslint-plugin-jest": "28.8.2",
    "eslint-plugin-jsx-a11y": "6.10.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.35.1",
    "eslint-plugin-react-hooks": "4.6.2",
    "globals": "17.5.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.0.0",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  }
}
